## 3. Create MudBlazor component

Create:

```text
Frontend/Pages/MediaUpload.razor
```

```razor
@page "/media-upload"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@implements IAsyncDisposable

@inject IJSRuntime JS

<MudPaper Class="pa-6" Elevation="2">

    <MudText Typo="Typo.h5" Class="mb-2">
        Media Upload
    </MudText>

    <MudText Typo="Typo.body2" Class="mb-4">
        Upload audio/video files using parallel chunk uploads.
    </MudText>

    <MudGrid Class="mb-4">

        <MudItem xs="12" md="4">
            <MudSelect T="int"
                       Label="Parallel uploads"
                       @bind-Value="_parallelUploadLimit">
                <MudSelectItem Value="1">1</MudSelectItem>
                <MudSelectItem Value="2">2</MudSelectItem>
                <MudSelectItem Value="3">3</MudSelectItem>
                <MudSelectItem Value="4">4</MudSelectItem>
                <MudSelectItem Value="5">5</MudSelectItem>
                <MudSelectItem Value="6">6</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudSelect T="int"
                       Label="Chunk size"
                       @bind-Value="_chunkSizeInMb">
                <MudSelectItem Value="5">5 MB</MudSelectItem>
                <MudSelectItem Value="10">10 MB</MudSelectItem>
                <MudSelectItem Value="25">25 MB</MudSelectItem>
                <MudSelectItem Value="50">50 MB</MudSelectItem>
            </MudSelect>
        </MudItem>

    </MudGrid>

    <MudPaper Class="pa-4 mb-4" Outlined="true">
        <InputFile OnChange="OnFilesSelected"
                   multiple
                   accept="audio/*,video/*" />
    </MudPaper>

    <MudStack Row="true" Spacing="2" Class="mb-4">
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!_selectedFiles.Any() || _isUploading)"
                   OnClick="StartUploadAsync">
            Start Upload
        </MudButton>

        <MudButton Color="Color.Default"
                   Variant="Variant.Outlined"
                   Disabled="@_isUploading"
                   OnClick="ClearFiles">
            Clear
        </MudButton>
    </MudStack>

    @if (_selectedFiles.Any())
    {
        <MudText Typo="Typo.subtitle1" Class="mb-2">
            Selected Files
        </MudText>

        @foreach (var file in _selectedFiles)
        {
            var progress = GetProgress(file.Name);

            <MudPaper Class="pa-3 mb-2" Outlined="true">
                <MudText Typo="Typo.body2">
                    @file.Name
                </MudText>

                <MudText Typo="Typo.caption">
                    @FormatBytes(file.Size)
                </MudText>

                <MudProgressLinear Value="@progress"
                                   Color="Color.Primary"
                                   Class="mt-2" />

                <MudText Typo="Typo.caption">
                    @progress%
                </MudText>
            </MudPaper>
        }
    }

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <MudAlert Severity="@_alertSeverity" Class="mt-4">
            @_statusMessage
        </MudAlert>
    }

</MudPaper>

@code {
    private DotNetObjectReference<MediaUpload>? _dotNetRef;

    private readonly List<IBrowserFile> _selectedFiles = [];
    private readonly Dictionary<string, int> _progressByFile = [];

    private int _parallelUploadLimit = 4;
    private int _chunkSizeInMb = 10;

    private bool _isUploading;
    private string? _statusMessage;
    private Severity _alertSeverity = Severity.Info;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _selectedFiles.Clear();
        _progressByFile.Clear();

        foreach (var file in e.GetMultipleFiles())
        {
            _selectedFiles.Add(file);
            _progressByFile[file.Name] = 0;
        }

        _statusMessage = $"{_selectedFiles.Count} file(s) selected.";
        _alertSeverity = Severity.Info;
    }

    private async Task StartUploadAsync()
    {
        if (!_selectedFiles.Any())
            return;

        _isUploading = true;
        _statusMessage = "Upload started.";
        _alertSeverity = Severity.Info;

        var chunkSizeInBytes = _chunkSizeInMb * 1024 * 1024;

        await JS.InvokeVoidAsync(
            "mediaChunkUploader.uploadFiles",
            _selectedFiles,
            _dotNetRef,
            new
            {
                chunkSizeInBytes,
                parallelUploadLimit = _parallelUploadLimit,

                // If backend is same domain, leave empty.
                // If backend is different project/port, use:
                // backendBaseUrl = "https://localhost:7001"
                backendBaseUrl = "https://localhost:7001"
            });

        _isUploading = false;
    }

    private void ClearFiles()
    {
        _selectedFiles.Clear();
        _progressByFile.Clear();
        _statusMessage = null;
    }

    private int GetProgress(string fileName)
    {
        return _progressByFile.TryGetValue(fileName, out var progress)
            ? progress
            : 0;
    }

    [JSInvokable]
    public Task OnUploadProgress(string fileName, int percentage)
    {
        _progressByFile[fileName] = percentage;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnUploadCompleted(string fileName)
    {
        _progressByFile[fileName] = 100;
        _statusMessage = $"{fileName} uploaded successfully.";
        _alertSeverity = Severity.Success;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnUploadError(string fileName, string errorMessage)
    {
        _statusMessage = $"{fileName}: {errorMessage}";
        _alertSeverity = Severity.Error;
        _isUploading = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        double len = bytes;
        var order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.##} {sizes[order]}";
    }

    public ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
```

