Below is the **frontend only**.

## 1. Save JS file

Create:

```text
Frontend/wwwroot/js/mediaChunkUploader.js
```

```javascript
window.mediaChunkUploader = {
    uploadFiles: async function (files, dotNetRef, options) {
        const chunkSize = options.chunkSizeInBytes || 10485760;
        const parallelLimit = options.parallelUploadLimit || 4;
        const backendBaseUrl = options.backendBaseUrl || "";

        for (const file of files) {
            await this.uploadSingleFile(file, dotNetRef, {
                chunkSize,
                parallelLimit,
                backendBaseUrl
            });
        }
    },

    uploadSingleFile: async function (file, dotNetRef, options) {
        const totalChunks = Math.ceil(file.size / options.chunkSize);

        const startResponse = await fetch(`${options.backendBaseUrl}/api/MediaUpload/start`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                fileName: file.name,
                contentType: file.type,
                fileSize: file.size,
                chunkSizeInBytes: options.chunkSize,
                parallelUploadLimit: options.parallelLimit,
                uploadCategory: "media"
            })
        });

        const startJson = await startResponse.json();

        if (!startJson.status) {
            await dotNetRef.invokeMethodAsync("OnUploadError", file.name, startJson.message || "Could not start upload.");
            return;
        }

        const uploadId = startJson.result.uploadId;

        let uploadedChunks = 0;
        let nextChunkIndex = 0;

        const uploadChunk = async () => {
            while (nextChunkIndex < totalChunks) {
                const chunkIndex = nextChunkIndex++;
                const start = chunkIndex * options.chunkSize;
                const end = Math.min(start + options.chunkSize, file.size);
                const chunkBlob = file.slice(start, end);

                const formData = new FormData();
                formData.append("uploadId", uploadId);
                formData.append("chunkIndex", chunkIndex);
                formData.append("totalChunks", totalChunks);
                formData.append("fileName", file.name);
                formData.append("chunk", chunkBlob, `${file.name}.part${chunkIndex}`);

                const response = await fetch(`${options.backendBaseUrl}/api/MediaUpload/chunk`, {
                    method: "POST",
                    body: formData
                });

                const json = await response.json();

                if (!json.status) {
                    throw new Error(json.message || `Chunk ${chunkIndex} failed.`);
                }

                uploadedChunks++;

                const percentage = Math.round((uploadedChunks / totalChunks) * 100);

                await dotNetRef.invokeMethodAsync(
                    "OnUploadProgress",
                    file.name,
                    percentage);
            }
        };

        const workers = [];

        for (let i = 0; i < options.parallelLimit; i++) {
            workers.push(uploadChunk());
        }

        try {
            await Promise.all(workers);

            const completeResponse = await fetch(`${options.backendBaseUrl}/api/MediaUpload/complete`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    uploadId: uploadId,
                    fileName: file.name,
                    totalChunks: totalChunks,
                    chunkIndex: 0
                })
            });

            const completeJson = await completeResponse.json();

            if (!completeJson.status) {
                await dotNetRef.invokeMethodAsync("OnUploadError", file.name, completeJson.message || "Upload completion failed.");
                return;
            }

            await dotNetRef.invokeMethodAsync("OnUploadCompleted", file.name);
        }
        catch (error) {
            await dotNetRef.invokeMethodAsync("OnUploadError", file.name, error.message);
        }
    }
};
```

