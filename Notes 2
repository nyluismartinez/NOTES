# 3. Backend controller

### `OnPremChunkUploadController.cs`

```csharp
using Microsoft.AspNetCore.Mvc;
using SharedLibrary.Helpers;
using SharedLibrary.Utilities;
using TodoApi.Services;

namespace TodoApi.Controllers;

[ApiController]
[Route("api/[controller]")]
public class OnPremChunkUploadController : ControllerBase
{
    private readonly OnPremChunkUploadService _chunkUploadService;

    public OnPremChunkUploadController(OnPremChunkUploadService chunkUploadService)
    {
        _chunkUploadService = chunkUploadService;
    }

    /// <summary>
    /// Uploads one chunk of a large file to the on-prem server.
    /// </summary>
    /// <remarks>
    /// This endpoint receives one file chunk using multipart/form-data.
    ///
    /// Example form-data request:
    /// <pre>
    /// FileName    = large-video.mp4
    /// Folder      = case-123/folder-abc
    /// ChunkIndex  = 0
    /// TotalChunks = 10
    /// Chunk       = binary chunk file
    /// </pre>
    /// </remarks>
    /// <param name="request">Request containing file name, folder, chunk index, total chunks, and the chunk file.</param>
    /// <param name="cancellationToken">Cancellation token.</param>
    /// <returns>Information about the uploaded chunk.</returns>
    [HttpPost("file/upload-chunk")]
    [Consumes("multipart/form-data")]
    public async Task<OperationResult<OnPremChunkUploadResponseDto>> UploadChunk(
        [FromForm] OnPremChunkUploadRequest request,
        CancellationToken cancellationToken = default)
    {
        try
        {
            var result = await _chunkUploadService.UploadChunkAsync(
                request,
                cancellationToken);

            return OperationResult<OnPremChunkUploadResponseDto>.Success(result);
        }
        catch (Exception ex)
        {
            return OperationResult<OnPremChunkUploadResponseDto>.Failure(ex.Message);
        }
    }

    /// <summary>
    /// Completes a chunk upload by merging all uploaded chunks into the final file.
    /// </summary>
    /// <remarks>
    /// Example JSON request:
    /// <pre>
    /// {
    ///   "fileName": "large-video.mp4",
    ///   "folder": "case-123/folder-abc",
    ///   "totalChunks": 10
    /// }
    /// </pre>
    /// </remarks>
    /// <param name="request">Request containing the file name, folder, and total number of chunks.</param>
    /// <param name="cancellationToken">Cancellation token.</param>
    /// <returns>Final uploaded file information.</returns>
    [HttpPost("file/complete-upload")]
    public async Task<OperationResult<OnPremChunkUploadResponseDto>> CompleteUpload(
        [FromBody] OnPremChunkCompleteRequest request,
        CancellationToken cancellationToken = default)
    {
        try
        {
            var result = await _chunkUploadService.CompleteUploadAsync(
                request,
                cancellationToken);

            return OperationResult<OnPremChunkUploadResponseDto>.Success(result);
        }
        catch (Exception ex)
        {
            return OperationResult<OnPremChunkUploadResponseDto>.Failure(ex.Message);
        }
    }

    /// <summary>
    /// Deletes one uploaded file from the on-prem server.
    /// </summary>
    /// <remarks>
    /// Example JSON request:
    /// <pre>
    /// {
    ///   "fileName": "large-video.mp4",
    ///   "folder": "case-123/folder-abc"
    /// }
    /// </pre>
    /// </remarks>
    /// <param name="request">Request containing the folder and file name to delete.</param>
    /// <param name="cancellationToken">Cancellation token.</param>
    /// <returns>Delete result.</returns>
    [HttpDelete("file/delete-file")]
    public async Task<OperationResult<OnPremDeleteResponseDto>> DeleteFile(
        [FromBody] OnPremFileDeleteRequest request,
        CancellationToken cancellationToken = default)
    {
        try
        {
            var result = await _chunkUploadService.DeleteFileAsync(
                request,
                cancellationToken);

            if (!result.Deleted)
                return OperationResult<OnPremDeleteResponseDto>.Failure(result.Message);

            return OperationResult<OnPremDeleteResponseDto>.Success(result);
        }
        catch (Exception ex)
        {
            return OperationResult<OnPremDeleteResponseDto>.Failure(ex.Message);
        }
    }

    /// <summary>
    /// Deletes a folder from the on-prem server.
    /// </summary>
    /// <remarks>
    /// This endpoint can delete a folder and all files/subfolders inside it.
    ///
    /// Example JSON request:
    /// <pre>
    /// {
    ///   "folder": "case-123/folder-abc",
    ///   "cascadeDelete": true
    /// }
    /// </pre>
    /// </remarks>
    /// <param name="request">Request containing the folder path and cascade delete option.</param>
    /// <param name="cancellationToken">Cancellation token.</param>
    /// <returns>Delete result.</returns>
    [HttpDelete("folder/delete-folder")]
    public async Task<OperationResult<OnPremDeleteResponseDto>> DeleteFolder(
        [FromBody] OnPremFolderDeleteRequest request,
        CancellationToken cancellationToken = default)
    {
        try
        {
            var result = await _chunkUploadService.DeleteFolderAsync(
                request,
                cancellationToken);

            if (!result.Deleted)
                return OperationResult<OnPremDeleteResponseDto>.Failure(result.Message);

            return OperationResult<OnPremDeleteResponseDto>.Success(result);
        }
        catch (Exception ex)
        {
            return OperationResult<OnPremDeleteResponseDto>.Failure(ex.Message);
        }
    }
}
