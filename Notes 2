# 2. Backend service

### `OnPremChunkUploadService.cs`

```csharp
using SharedLibrary.Helpers;

namespace TodoApi.Services;

public class OnPremChunkUploadService
{
    private readonly IWebHostEnvironment _environment;
    private readonly string _rootPath;
    private readonly string _tempPath;

    public OnPremChunkUploadService(
        IConfiguration configuration,
        IWebHostEnvironment environment)
    {
        _environment = environment;

        var configuredPath = configuration["OnPremStorage:RootPath"] ?? "downloads/temp";

        _rootPath = Path.Combine(_environment.ContentRootPath, configuredPath);
        _tempPath = Path.Combine(_rootPath, "_chunks");
    }

    public async Task<OnPremChunkUploadResponseDto> UploadChunkAsync(
        OnPremChunkUploadRequest request,
        CancellationToken cancellationToken = default)
    {
        ValidateChunkRequest(request);

        var safeFileName = GetSafeFileName(request.FileName);
        var safeFolder = NormalizeFolder(request.Folder);

        var uploadId = CreateUploadId(safeFolder, safeFileName);
        var chunkFolder = Path.Combine(_tempPath, uploadId);

        Directory.CreateDirectory(chunkFolder);

        var chunkPath = Path.Combine(chunkFolder, $"chunk-{request.ChunkIndex:D8}.part");

        await using var sourceStream = request.Chunk.OpenReadStream();
        await using var targetStream = new FileStream(
            chunkPath,
            FileMode.Create,
            FileAccess.Write,
            FileShare.None,
            bufferSize: 1024 * 1024,
            useAsync: true);

        await sourceStream.CopyToAsync(targetStream, cancellationToken);

        return new OnPremChunkUploadResponseDto
        {
            FileName = safeFileName,
            Folder = safeFolder,
            ChunkIndex = request.ChunkIndex,
            TotalChunks = request.TotalChunks,
            IsCompleted = false,
            Size = request.Chunk.Length,
            UploadedUtc = DateTime.UtcNow
        };
    }

    public async Task<OnPremChunkUploadResponseDto> CompleteUploadAsync(
        OnPremChunkCompleteRequest request,
        CancellationToken cancellationToken = default)
    {
        if (string.IsNullOrWhiteSpace(request.FileName))
            throw new ArgumentException("FileName is required.");

        if (request.TotalChunks <= 0)
            throw new ArgumentException("TotalChunks must be greater than zero.");

        var safeFileName = GetSafeFileName(request.FileName);
        var safeFolder = NormalizeFolder(request.Folder);

        var uploadId = CreateUploadId(safeFolder, safeFileName);
        var chunkFolder = Path.Combine(_tempPath, uploadId);

        if (!Directory.Exists(chunkFolder))
            throw new DirectoryNotFoundException("Chunk folder was not found.");

        for (var i = 0; i < request.TotalChunks; i++)
        {
            var chunkPath = Path.Combine(chunkFolder, $"chunk-{i:D8}.part");

            if (!File.Exists(chunkPath))
                throw new FileNotFoundException($"Missing chunk {i}.");
        }

        var finalFolder = Path.Combine(_rootPath, safeFolder);
        Directory.CreateDirectory(finalFolder);

        var finalPath = Path.Combine(finalFolder, safeFileName);

        await using var finalStream = new FileStream(
            finalPath,
            FileMode.Create,
            FileAccess.Write,
            FileShare.None,
            bufferSize: 1024 * 1024,
            useAsync: true);

        for (var i = 0; i < request.TotalChunks; i++)
        {
            var chunkPath = Path.Combine(chunkFolder, $"chunk-{i:D8}.part");

            await using var chunkStream = new FileStream(
                chunkPath,
                FileMode.Open,
                FileAccess.Read,
                FileShare.Read,
                bufferSize: 1024 * 1024,
                useAsync: true);

            await chunkStream.CopyToAsync(finalStream, cancellationToken);
        }

        Directory.Delete(chunkFolder, recursive: true);

        var fileInfo = new FileInfo(finalPath);

        return new OnPremChunkUploadResponseDto
        {
            FileName = safeFileName,
            Folder = safeFolder,
            ChunkIndex = request.TotalChunks - 1,
            TotalChunks = request.TotalChunks,
            IsCompleted = true,
            FinalPath = finalPath,
            Size = fileInfo.Length,
            UploadedUtc = DateTime.UtcNow
        };
    }

    public Task<OnPremDeleteResponseDto> DeleteFileAsync(
        OnPremFileDeleteRequest request,
        CancellationToken cancellationToken = default)
    {
        if (string.IsNullOrWhiteSpace(request.FileName))
            throw new ArgumentException("FileName is required.");

        var safeFileName = GetSafeFileName(request.FileName);
        var safeFolder = NormalizeFolder(request.Folder);

        var filePath = Path.Combine(_rootPath, safeFolder, safeFileName);

        if (!File.Exists(filePath))
        {
            return Task.FromResult(new OnPremDeleteResponseDto
            {
                Deleted = false,
                DeletedPath = filePath,
                Message = "File not found."
            });
        }

        File.Delete(filePath);

        return Task.FromResult(new OnPremDeleteResponseDto
        {
            Deleted = true,
            DeletedPath = filePath,
            Message = "File deleted successfully."
        });
    }

    public Task<OnPremDeleteResponseDto> DeleteFolderAsync(
        OnPremFolderDeleteRequest request,
        CancellationToken cancellationToken = default)
    {
        var safeFolder = NormalizeFolder(request.Folder);

        if (string.IsNullOrWhiteSpace(safeFolder))
            throw new ArgumentException("Folder is required.");

        var folderPath = Path.Combine(_rootPath, safeFolder);

        if (!Directory.Exists(folderPath))
        {
            return Task.FromResult(new OnPremDeleteResponseDto
            {
                Deleted = false,
                DeletedPath = folderPath,
                Message = "Folder not found."
            });
        }

        Directory.Delete(folderPath, recursive: request.CascadeDelete);

        return Task.FromResult(new OnPremDeleteResponseDto
        {
            Deleted = true,
            DeletedPath = folderPath,
            Message = request.CascadeDelete
                ? "Folder and all files were deleted successfully."
                : "Folder deleted successfully."
        });
    }

    private static void ValidateChunkRequest(OnPremChunkUploadRequest request)
    {
        if (string.IsNullOrWhiteSpace(request.FileName))
            throw new ArgumentException("FileName is required.");

        if (request.Chunk == null || request.Chunk.Length == 0)
            throw new ArgumentException("Chunk is required.");

        if (request.ChunkIndex < 0)
            throw new ArgumentException("ChunkIndex cannot be negative.");

        if (request.TotalChunks <= 0)
            throw new ArgumentException("TotalChunks must be greater than zero.");

        if (request.ChunkIndex >= request.TotalChunks)
            throw new ArgumentException("ChunkIndex cannot be greater than or equal to TotalChunks.");
    }

    private static string NormalizeFolder(string? folder)
    {
        if (string.IsNullOrWhiteSpace(folder))
            return string.Empty;

        var cleanFolder = folder
            .Trim()
            .Trim('/', '\\')
            .Replace("/", Path.DirectorySeparatorChar.ToString())
            .Replace("\\", Path.DirectorySeparatorChar.ToString());

        return cleanFolder;
    }

    private static string GetSafeFileName(string fileName)
    {
        var safeFileName = Path.GetFileName(fileName);

        if (string.IsNullOrWhiteSpace(safeFileName))
            throw new ArgumentException("Invalid file name.");

        return safeFileName;
    }

    private static string CreateUploadId(string folder, string fileName)
    {
        var raw = $"{folder}_{fileName}".Replace("\\", "_").Replace("/", "_");

        foreach (var invalidChar in Path.GetInvalidFileNameChars())
        {
            raw = raw.Replace(invalidChar, '_');
        }

        return raw;
    }
}
