## Backend controller

Save in:

```text
Backend/Controllers/MediaUploadController.cs
```

```csharp
using Microsoft.AspNetCore.Mvc;
using SharedLibrary.DTOs.Upload;
using SharedLibrary.Wrappers;

namespace Backend.Controllers;

[ApiController]
[Route("api/[controller]")]
public class MediaUploadController : ControllerBase
{
    private readonly MediaUploadService _mediaUploadService;

    public MediaUploadController(MediaUploadService mediaUploadService)
    {
        _mediaUploadService = mediaUploadService;
    }

    [HttpPost("start")]
    public async Task<ActionResult<OperationResult<UploadSessionResponse>>> StartUpload(
        [FromBody] UploadSettingsRequest request,
        CancellationToken cancellationToken)
    {
        var result = await _mediaUploadService.StartUploadAsync(request, cancellationToken);
        return Ok(result);
    }

    [HttpPost("chunk")]
    [RequestSizeLimit(long.MaxValue)]
    public async Task<ActionResult<OperationResult<bool>>> UploadChunk(
        [FromForm] Guid uploadId,
        [FromForm] int chunkIndex,
        [FromForm] int totalChunks,
        [FromForm] string fileName,
        [FromForm] IFormFile chunk,
        CancellationToken cancellationToken)
    {
        var result = await _mediaUploadService.SaveChunkAsync(
            uploadId,
            chunkIndex,
            totalChunks,
            fileName,
            chunk,
            cancellationToken);

        return Ok(result);
    }

    [HttpPost("complete")]
    public async Task<ActionResult<OperationResult<string>>> CompleteUpload(
        [FromBody] UploadChunkRequest request,
        CancellationToken cancellationToken)
    {
        var result = await _mediaUploadService.CompleteUploadAsync(request, cancellationToken);
        return Ok(result);
    }
}
```

## Backend service

Save in:

```text
Backend/Services/MediaUploadService.cs
```

```csharp
using SharedLibrary.DTOs.Upload;
using SharedLibrary.Wrappers;

namespace Backend.Services;

public class MediaUploadService
{
    private readonly IWebHostEnvironment _environment;

    public MediaUploadService(IWebHostEnvironment environment)
    {
        _environment = environment;
    }

    public Task<OperationResult<UploadSessionResponse>> StartUploadAsync(
        UploadSettingsRequest request,
        CancellationToken cancellationToken = default)
    {
        var uploadId = Guid.NewGuid();

        var totalChunks = (int)Math.Ceiling(
            request.FileSize / (double)request.ChunkSizeInBytes);

        var response = new UploadSessionResponse
        {
            UploadId = uploadId,
            FileName = request.FileName,
            ChunkSizeInBytes = request.ChunkSizeInBytes,
            ParallelUploadLimit = request.ParallelUploadLimit,
            TotalChunks = totalChunks
        };

        var folder = GetUploadFolder(uploadId);
        Directory.CreateDirectory(folder);

        return Task.FromResult(OperationResult<UploadSessionResponse>.Success(response));
    }

    public async Task<OperationResult<bool>> SaveChunkAsync(
        Guid uploadId,
        int chunkIndex,
        int totalChunks,
        string fileName,
        IFormFile chunk,
        CancellationToken cancellationToken = default)
    {
        var folder = GetUploadFolder(uploadId);
        Directory.CreateDirectory(folder);

        var chunkPath = Path.Combine(folder, $"{chunkIndex}.chunk");

        await using var stream = new FileStream(chunkPath, FileMode.Create, FileAccess.Write);
        await chunk.CopyToAsync(stream, cancellationToken);

        return OperationResult<bool>.Success(true, $"Chunk {chunkIndex + 1}/{totalChunks} uploaded.");
    }

    public async Task<OperationResult<string>> CompleteUploadAsync(
        UploadChunkRequest request,
        CancellationToken cancellationToken = default)
    {
        var folder = GetUploadFolder(request.UploadId);
        var finalFilePath = Path.Combine(folder, request.FileName);

        await using var finalStream = new FileStream(finalFilePath, FileMode.Create);

        for (var i = 0; i < request.TotalChunks; i++)
        {
            var chunkPath = Path.Combine(folder, $"{i}.chunk");

            if (!File.Exists(chunkPath))
                return OperationResult<string>.Failure($"Missing chunk {i}.");

            await using var chunkStream = new FileStream(chunkPath, FileMode.Open, FileAccess.Read);
            await chunkStream.CopyToAsync(finalStream, cancellationToken);
        }

        // Here call your existing FFmpeg method.
        // await _ffmpegService.ConvertToWavAsync(finalFilePath, wavOutputPath);

        // Then upload WAV to Blob Storage.
        // await _blobStorageService.UploadFileAsync(wavOutputPath, blobPath);

        return OperationResult<string>.Success(finalFilePath, "Upload completed and file assembled.");
    }

    private string GetUploadFolder(Guid uploadId)
    {
        return Path.Combine(
            _environment.ContentRootPath,
            "Uploads",
            "Media",
            uploadId.ToString());
    }
}
```

