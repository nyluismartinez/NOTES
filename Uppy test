# Step 5 — Configure Tus in `Program.cs`

Save/update:

```text
Backend/Program.cs
```

Add these usings:

```csharp
using Backend.Services;
using Backend.Settings;
using tusdotnet;
using tusdotnet.Models;
using tusdotnet.Stores;
```

Add services:

```csharp
builder.Services.Configure<UploadSettings>(
    builder.Configuration.GetSection("UploadSettings"));

builder.Services.AddScoped<MediaProcessingService>();
```

Before `app.Run();`, add:

```csharp
var uploadSettings = app.Services
    .GetRequiredService<IConfiguration>()
    .GetSection("UploadSettings")
    .Get<UploadSettings>()!;

Directory.CreateDirectory(uploadSettings.TusTempFolder);

app.UseTus(httpContext =>
{
    return Task.FromResult(new DefaultTusConfiguration
    {
        Store = new TusDiskStore(uploadSettings.TusTempFolder),

        UrlPath = "/files/media",

        Events = new Events
        {
            OnFileCompleteAsync = async eventContext =>
            {
                using var scope = app.Services.CreateScope();

                var mediaProcessingService =
                    scope.ServiceProvider.GetRequiredService<MediaProcessingService>();

                var file = await eventContext.GetFileAsync();

                var metadata = await file.GetMetadataAsync(eventContext.CancellationToken);

                var originalFileName = metadata.TryGetValue("filename", out var fileNameMetadata)
                    ? fileNameMetadata.GetString(System.Text.Encoding.UTF8)
                    : $"{file.Id}.media";

                var uploadedFilePath = Path.Combine(uploadSettings.TusTempFolder, file.Id);

                await mediaProcessingService.ProcessUploadedMediaAsync(
                    uploadedFilePath,
                    originalFileName,
                    eventContext.CancellationToken);
            }
        }
    });
});
```

