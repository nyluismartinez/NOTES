    private DotNetObjectReference<MediaUpload>? _dotNetRef;
    private int _maxParallelUploads = 4;

    private readonly List<UploadProgressItem> _progressItems = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync(
                "uppyMediaUploader.init",
                "uppy-media-dashboard",
                _dotNetRef,
                new
                {
                    maxParallelUploads = _maxParallelUploads,
                    tusEndpoint = "/files/media"
                });
        }
    }

    private async Task StartUpload()
    {
        await JS.InvokeVoidAsync("uppyMediaUploader.upload");
    }

    private async Task CancelUpload()
    {
        await JS.InvokeVoidAsync("uppyMediaUploader.cancelAll");
    }

    [JSInvokable]
    public Task OnUploadProgress(string fileName, int percentage)
    {
        var existing = _progressItems.FirstOrDefault(x => x.FileName == fileName);

        if (existing is null)
        {
            _progressItems.Add(new UploadProgressItem
            {
                FileName = fileName,
                Percentage = percentage
            });
        }
        else
        {
            existing.Percentage = percentage;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnUploadComplete(int successfulCount, int failedCount)
    {
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnUploadError(string fileName, string errorMessage)
    {
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }

    private class UploadProgressItem
    {
        public string FileName { get; set; } = "";
        public int Percentage { get; set; }
    }
}
