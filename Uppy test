# Step 7 — Create JavaScript uploader

Save as:

```text
Frontend/wwwroot/js/uppyMediaUploader.js
```

```javascript
window.uppyMediaUploader = {
    instance: null,

    init: function (elementId, dotNetRef, options) {
        const maxParallelUploads = options.maxParallelUploads || 4;
        const tusEndpoint = options.tusEndpoint || "/files/media";

        const uppy = new Uppy.Uppy({
            autoProceed: false,
            restrictions: {
                allowedFileTypes: [
                    "audio/*",
                    "video/*"
                ]
            }
        });

        uppy.use(Uppy.Dashboard, {
            inline: true,
            target: "#" + elementId,
            proudlyDisplayPoweredByUppy: false,
            showProgressDetails: true,
            height: 420
        });

        uppy.use(Uppy.Tus, {
            endpoint: tusEndpoint,
            limit: maxParallelUploads,
            retryDelays: [0, 1000, 3000, 5000]
        });

        uppy.on("upload-progress", function (file, progress) {
            const percentage = progress.bytesTotal
                ? Math.round((progress.bytesUploaded / progress.bytesTotal) * 100)
                : 0;

            dotNetRef.invokeMethodAsync(
                "OnUploadProgress",
                file.name,
                percentage);
        });

        uppy.on("complete", function (result) {
            dotNetRef.invokeMethodAsync(
                "OnUploadComplete",
                result.successful.length,
                result.failed.length);
        });

        uppy.on("upload-error", function (file, error) {
            dotNetRef.invokeMethodAsync(
                "OnUploadError",
                file.name,
                error.message || "Upload failed");
        });

        window.uppyMediaUploader.instance = uppy;
    },

    upload: function () {
        if (window.uppyMediaUploader.instance) {
            window.uppyMediaUploader.instance.upload();
        }
    },

    cancelAll: function () {
        if (window.uppyMediaUploader.instance) {
            window.uppyMediaUploader.instance.cancelAll();
        }
    }
};
```

